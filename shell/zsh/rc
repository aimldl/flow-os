# --------------------------------------------------
# 🔥 Prompt
# --------------------------------------------------

setopt PROMPT_SUBST

_set_prompt() {
    local dir

    if [[ "$PWD" == "$HOME" ]]; then
        dir="~"
    elif [[ "$PWD" == "$HOME/"* ]]; then
        dir="${PWD#$HOME/}"
    else
        dir="$PWD"
    fi

    dir="${dir/#~\//}"

    PROMPT="${dir} %% "
}

autoload -U add-zsh-hook
add-zsh-hook precmd _set_prompt
_set_prompt