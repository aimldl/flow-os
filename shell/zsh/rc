# --------------------------------------------------
# 🔄 Smart Git Sync (startup)
# 🔄 스마트 Git 동기화 (터미널 시작 시)
# --------------------------------------------------

source "$HOME/.flow-os/bin/lib-git"

if command -v git >/dev/null && git_is_online; then
    if git_should_sync; then
        echo "🔄 Syncing repos..."
        git-pull >/dev/null 2>&1
        git_mark_synced
    else
        mins=$(git_minutes_since_sync)
        echo "✅ Sync skipped (sync'd ${mins} min ago)"
    fi
fi

