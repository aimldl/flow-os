# --------------------------------------------------
# ⚙️ ZSH Config (My OS 2.0)
# --------------------------------------------------

# -------------------------
# 🔑 Secrets (optional)
# -------------------------
[ -f "$HOME/.secrets" ] && source "$HOME/.secrets"

# -------------------------
# 🧠 System Root
# -------------------------
export MY_HOME="$HOME/my"

# -------------------------
# 🔄 Sync Policy
#     기본 3시간 = 180분
# -------------------------
export SYNC_INTERVAL_MINUTES="${SYNC_INTERVAL_MINUTES:-180}"

# -------------------------
# 🖊 Default Editor Policy
#    macOS: TextEdit
#    Linux: nano
# -------------------------
case "$(uname -s)" in
  Darwin)
    export EDITOR="open -a TextEdit"
    ;;
  Linux)
    export EDITOR="nano"
    ;;
  *)
    export EDITOR="nano"
    ;;
esac

# -------------------------
# 🐍 Python (mac only)
# -------------------------
if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
    export PATH="$(brew --prefix)/opt/python/libexec/bin:$PATH"
fi

# -------------------------
# 🧰 Custom Tools
# -------------------------
[ -d "$HOME/.antigravity/antigravity/bin" ] && \
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# -------------------------
# ⚡ Quality of Life
# -------------------------
export CLICOLOR=1
export LSCOLORS=ExFxBxDxCxegedabagacad