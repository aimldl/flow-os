# --------------------------------------------------
# ⚡ Aliases (Fully Alphabetical) (My OS 2.0)
# --------------------------------------------------

alias a='alias'
alias b='bash'

alias c='cd'
alias c4='chmod 400'
alias cl='clear'
alias core='cd ~/my/github/python-core'
alias cx='chmod +x'

alias da='docker attach'
alias dc='docker commit'
alias dl='docker login'
alias dp='docker ps'
alias dpull='docker pull'
alias dpush='docker push'
alias dr='docker run -it'
alias ds='docker stop'

alias e='exit'
alias edit='__edit'

alias f='find . -name'
alias fd='find . -type d -name'
alias ff='find . -type f -name'

alias g='egrep -n'
alias gg='cd ~/my/github'
alias ginit='bash ~/my/github/init.sh'
alias go='__resume_open 1'
alias go2='__resume_open 2'
alias go3='__resume_open 3'
alias gpush='bash ~/my/github/push.sh'
alias gstatus='bash ~/my/github/status.sh'
alias gsync='bash ~/my/github/sync.sh'

alias h='history'

alias l='ls'
alias la='ls -A'
alias last='ls -t | head -5'
alias ll='ls -alF'

alias m='cd ~/my'
alias my='cd ~/my'
alias myls='ls ~/my'

alias n='nano'

alias o='__edit'
alias os='__edit ~/OS.md'

alias p='pwd'
alias play='cd ~/my/github/python-playground'
alias python='python3'

alias q='quit'
alias qq='quit_quick'

alias resume='__edit ~/RESUME.md'

alias s='source ~/.zshrc'
alias search='grep -Rin '

alias t='tree -d -L 1'
alias t2='tree -d -L 2'
alias tmp='cd ~/my/tmp'
alias todo='__edit ~/TODO.md'

alias z='__edit ~/.zshrc'
alias za='__edit ~/.zshalias'
alias zc='__edit ~/.zshconfig'