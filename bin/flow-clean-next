#!/usr/bin/env bash
# flow-clean-next — Archive [v]/[x] items to v-next-YYYY-MM.md, keep unfinished items in next.md
# flow-clean-next — [v]/[x] 항목만 v-next-YYYY-MM.md로 이동, 미완료 항목은 next.md에 그대로 유지

source "$HOME/.flow-os/bin/lib-path"

CORE="$FLOW_CORE/next.md"

[ -f "$CORE" ] || exit

today=$(flow_today)
today_full=$(flow_today_full)
ym="${today:0:7}"

TARGET="$FLOW_CORE/v-next-$ym.md"

# ✅ Archive completed items ([v] or [x]) to monthly file
# ✅ 완료된 항목 ([v] 또는 [x])을 월별 파일로 이동
completed=$(grep -E '^\[(v|x)\]' "$CORE" 2>/dev/null || true)

if [ -n "$completed" ] && ! grep -q "^   $today" "$TARGET" 2>/dev/null; then
    {
        printf -- "   %s\n%s\n---\n" "$today_full" "$completed"
        [ -f "$TARGET" ] && cat "$TARGET"
    } > "$TARGET.tmp"
    mv "$TARGET.tmp" "$TARGET"
fi

# ✅ Rebuild next.md: static header + all non-completed lines, unchanged and unpadded
# ✅ next.md 재작성: 정적 헤더 + 완료되지 않은 모든 줄 (변경/패딩 없이 그대로 유지)
kept=$(grep -v -E '^\[(v|x)\]' "$CORE" | sed '/^# next$/d' | sed '/./,$!d')

{
  echo "# next"
  [ -n "$kept" ] && printf '%s\n' "$kept"
} > "$CORE"

echo "✅ next cleaned"
