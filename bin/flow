#!/usr/bin/env bash

cmd="$1"
shift

case "$cmd" in

    memo)
        file="$HOME/flow-entry/temporary/memo.md"

        if [ -z "$*" ]; then
            read -r "msg?📝 "
        else
            msg="$*"
        fi

        echo "- $(date '+%H:%M') $msg" >> "$file"
        echo "📝 memo saved"
        ;;

    next)
        file="$HOME/.flow/core/NEXT.md"

        if [ -n "$1" ]; then
            target="$1"
        else
            target="$PWD"
        fi

        echo "# NEXT" > "$file"
        echo "" >> "$file"
        echo "$target" >> "$file"

        echo "✅ NEXT updated: $target"
        ;;

    organize)
        target="${1:-memo}"

        case "$target" in
            memo)
                if [ "$(uname -s)" = "Darwin" ]; then
                    open -a TextEdit "$HOME/flow-entry/temporary/memo.md"
                else
                    nano "$HOME/flow-entry/temporary/memo.md"
                fi
                echo "⚠️ Remember to clean up memo manually"
                ;;
            *)
                echo "Unknown organize target: $target"
                ;;
        esac
        ;;

    push)
        cd "$HOME/.flow-os" || exit 1

        git add .

        if [ -n "$*" ]; then
            msg="$*"
        else
            msg="update $(date '+%Y-%m-%d %H:%M')"
        fi

        git commit -m "$msg" 2>/dev/null
        git push

        echo "📦 Flow OS push..."
        echo "✅ push completed"
        ;;

    pull)
        cd "$HOME/.flow-os" || exit 1

        git pull

        echo "⬇️ Flow OS pull..."
        echo "✅ up to date"
        ;;

    quit)
        exec quit "$@"
        ;;

    quick_quit)
        exec quick_quit "$@"
        ;;

    *)
        echo "Usage:"
        echo "  flow memo <text>"
        echo "  flow next [path]"
        echo "  flow organize [target]"
        echo "  flow push [message]"
        echo "  flow pull"
        echo "  flow quit"
        echo "  flow quick_quit"
        ;;
esac
