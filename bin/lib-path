#!/usr/bin/env bash
# lib-path — Flow OS path constants and path conversion utilities
# Usage: source "$HOME/.flow-os/bin/lib-path"
# Provides: FLOW_CORE, flow_relative_path, flow_pretty_path
# Depends: lib-date

# lib-path — Flow OS 경로 상수 및 경로 변환 유틸리티
# 사용법: source "$HOME/.flow-os/bin/lib-path"
# 제공: FLOW_CORE, flow_relative_path, flow_pretty_path
# 의존: lib-date

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  echo "This is a library"
  exit 1
fi

source "$HOME/.flow-os/bin/lib-date"

# State files root (resume.md, todo.md, memo.md, next.md, v-*.md)
# 상태 파일 루트 (resume.md, todo.md, memo.md, next.md, v-*.md)
FLOW_CORE="$HOME/my/.flow"

# Convert PWD to ~ or HOME-relative path
# PWD를 ~ 또는 HOME 기준 상대 경로로 변환
flow_relative_path() {
    if [[ "$PWD" == "$HOME" ]]; then
        echo "~"
    elif [[ "$PWD" == "$HOME/"* ]]; then
        echo "${PWD#$HOME/}"
    else
        echo "$PWD"
    fi
}

# Strip $HOME/ prefix for display
# 절대 경로에서 $HOME/ 접두사를 제거하여 출력용 경로 반환
flow_pretty_path() {
    echo "${1/#$HOME\//}"
}
