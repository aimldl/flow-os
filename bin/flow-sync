#!/bin/bash

ts=$(date +%H_%M)
day=$(date +%Y-%m-%d)

ARCHIVE_DIR="$HOME/.flow/$day"
STATE_DIR="$HOME/flow-state"
ENTRY_DIR="$HOME/flow-entry"

mkdir -p "$ARCHIVE_DIR"

# state -> archive 저장
if [ -d "$STATE_DIR" ] && [ "$(ls -A "$STATE_DIR" 2>/dev/null)" ]; then
  cp -R "$STATE_DIR" "$ARCHIVE_DIR/$ts"
fi

# state 초기화 후 entry 복사
rm -rf "$STATE_DIR"/*
cp -R "$ENTRY_DIR"/* "$STATE_DIR"

clear

echo "✅ Flow synced"
echo ""

echo "🧭 FLOW TODAY"
for d in "$STATE_DIR"/[1-9]-*; do
  [ -e "$d" ] || continue
  name=$(basename "$d" | cut -d- -f2-)
  num=$(basename "$d" | cut -d- -f1)
  echo "$num. $name"
done

echo ""
echo "📦 Inbox"
ls "$STATE_DIR"/temporary 2>/dev/null | sed 's|.*/||'

echo ""
echo "🚀 Resume"
first=$(ls "$STATE_DIR"/[1-9]-* 2>/dev/null | head -n 1)
echo "$first"

echo ""
echo "Opening flow-state..."
code "$STATE_DIR"
