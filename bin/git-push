#!/usr/bin/env bash
set -e

TARGET="$HOME/my/craft"

echo "📦 git push..."

for dir in "$TARGET"/*/; do
  [ -d "$dir/.git" ] || continue
  cd "$dir" || continue

  name=$(basename "$dir")

  status=$(git status --porcelain)

  if [ -n "$status" ]; then

  echo "✅ $name (updated)"

  git add .

  git commit -m "auto: $(date '+%Y-%m-%d %H:%M')" >/dev/null 2>&1 || true

  git push >/dev/null 2>&1 || true

 else

  echo "• $name (clean)"

 fi

done

echo "✅ done"
