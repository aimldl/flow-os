#!/usr/bin/env bash
# flow-clean-memo — Archive memo.md to daily history and reset
# flow-clean-memo — memo.md를 날짜별 history로 아카이브하고 초기화

source "$HOME/.flow-os/bin/lib-path"

CORE="$FLOW_CORE/memo.md"

[ -f "$CORE" ] || exit

DIR="$FLOW_HISTORY/$(flow_history_dir)"
mkdir -p "$DIR"

TARGET="$DIR/memo.md"

# ✅ Append to existing history file, or create new one
# ✅ 기존 파일 있으면 append, 없으면 새로 생성
if [ -f "$TARGET" ]; then
  echo "" >> "$TARGET"
  echo "## $(flow_today) ($(flow_weekday))" >> "$TARGET"
  sed '1{/^# memo$/d;}' "$CORE" >> "$TARGET"
  echo "" >> "$TARGET"
else
  cp "$CORE" "$TARGET"
  echo "" >> "$TARGET"
fi

# ✅ Reset core memo.md
# ✅ CORE memo.md 초기화
echo "# memo" > "$CORE"

echo "✅ memo archived to $(flow_pretty_path "$TARGET")"
