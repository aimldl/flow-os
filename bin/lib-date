#!/usr/bin/env bash
# lib-date — Date/time utilities and localized messages (ko/en/ja)
# Usage: source "$HOME/.flow-os/bin/lib-date"
# Env:   FLOW_LANG (default: ko)

# lib-date — 날짜/시간 유틸리티 및 다국어 메시지 (ko/en/ja)
# 사용법: source "$HOME/.flow-os/bin/lib-date"
# 환경변수: FLOW_LANG (기본값: ko)

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  echo "This is a library"
  exit 1
fi

# --- Date/Time ---
# --- 날짜/시간 ---

flow_lang() {
  echo "${FLOW_LANG:-ko}"
}

# Localized weekday name
# 로케일별 요일 이름 반환
flow_weekday() {
  local lang weekday
  lang="$(flow_lang)"
  weekday="$(date '+%u')"

  case "$lang" in
    ko) days=(월 화 수 목 금 토 일) ;;
    en) days=(Mon Tue Wed Thu Fri Sat Sun) ;;
    ja) days=(月 火 水 木 金 土 日) ;;
    *)  days=(월 화 수 목 금 토 일) ;;
  esac

  echo "${days[$((weekday-1))]}"
}

# YYYY-MM-DD
flow_today() {
  date '+%Y-%m-%d'
}

# HH:MM
flow_time() {
  date '+%H:%M'
}

# YYYY-MM-DD-weekday (e.g. 2026-06-28-일)
# YYYY-MM-DD-요일 형식
flow_today_full() {
  echo "$(flow_today)-$(flow_weekday)"
}

# --- Localized messages (used during quit) ---
# --- 다국어 메시지 (quit 시 사용) ---

flow_open_message() {
  local lang
  lang="$(flow_lang)"

  case "$lang" in
    ko) echo "👀 resume.md를 열어 검수합니다..." ;;
    en) echo "👀 Opening resume.md for review..." ;;
    ja) echo "👀 resume.md を開いて確認します..." ;;
    *)  echo "👀 resume.md를 열어 검수합니다..." ;;
  esac
}

flow_quit_prompt() {
  local lang
  lang="$(flow_lang)"

  case "$lang" in
    ko) echo "✅ RESUME 검수 후 종료하려면 Enter (취소: Ctrl+C): " ;;
    en) echo "✅ Press Enter to quit after checking RESUME (Ctrl+C to cancel): " ;;
    ja) echo "✅ RESUMEを確認したらEnterで終了 (キャンセル: Ctrl+C): " ;;
    *)  echo "✅ RESUME 검수 후 종료하려면 Enter (취소: Ctrl+C): " ;;
  esac
}

flow_quick_exit_message() {
  local lang
  lang="$(flow_lang)"

  case "$lang" in
    ko) echo "⚡ 빠른 종료" ;;
    en) echo "⚡ Quick exit" ;;
    ja) echo "⚡ クイック終了" ;;
    *)  echo "⚡ 빠른 종료" ;;
  esac
}
