#!/usr/bin/env bash
# git-init — Clone repos listed in git-target-repos
# Alias: ginit

# git-init — git-target-repos에 등록된 repo들을 클론
# 별칭: ginit

source "$HOME/.flow-os/bin/lib-git"
git_load_config

echo "🚀 Initializing repos..."

for entry in "${ALL_REPOS[@]}"; do
    path="$(git_repo_path "$entry")"
    url="$(git_repo_url "$entry")"
    dir="$REPO_BASE/$path"

    mkdir -p "$(dirname "$dir")"

    if [ -d "$dir/.git" ]; then
        echo "⏭️  $path exists"
    else
        git clone "$url" "$dir"
        echo "✅ cloned $path"
    fi
done

echo "✅ done"
