#!/usr/bin/env bash
# git-status — Show dirty/clean status of all config-defined git repos
# Alias: gstatus

# git-status — 설정된 모든 git repo의 dirty/clean 상태 표시
# 별칭: gstatus

source "$HOME/.flow-os/bin/lib-git"

while IFS= read -r dir; do
  [ -d "$dir/.git" ] || continue
  cd "$dir"
  name=$(basename "$(realpath "$dir")")

  if [[ $(git status --porcelain) ]]; then
    echo "⚠️  $name dirty"
  else
    echo "✅ $name clean"
  fi
done < <(git_all_repo_dirs)
