#!/usr/bin/env bash
# flow-quit — Standard quit: git push → save RESUME → review → close terminal
# Alias: q, quit, fquit

# flow-quit — 표준 종료: git push → RESUME 저장 → 검수 → 터미널 닫기
# 별칭: q, quit, fquit

source "$HOME/.flow-os/bin/lib-resume"
source "$HOME/.flow-os/bin/lib-git"

target=$(flow_relative_path)

# Auto-commit & push all repos (skip if offline)
# 모든 repo를 자동 커밋 & push (오프라인 시 건너뜀)
if git_is_online; then
    echo "📦 sync repos"
    git-push >/dev/null 2>&1
else
    echo "⚠️ offline → skip sync"
fi

# Save current location as entry point for next session's `go`
# 현재 위치를 다음 세션의 go 진입점으로 저장
flow_save_resume "$target"
echo "$(flow_open_message)"

# Open resume.md for user review before closing
# resume.md를 열어 사용자가 검수할 수 있도록 대기
if [[ "$OSTYPE" == "darwin"* ]]; then
    open -a TextEdit "$FLOW_CORE/resume.md"
fi

printf "%s" "$(flow_quit_prompt)"
read -r

echo "👋 Closing session..."
flow_close_terminal
