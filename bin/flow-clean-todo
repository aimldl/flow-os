#!/usr/bin/env bash
# flow-clean-todo — Archive completed tasks ([v]/[x]) to history, pad to 3 open slots
# flow-clean-todo — 완료된 할 일([v]/[x])을 history로 아카이브하고, 총 3개가 되도록 빈 항목 추가

source "$HOME/.flow-os/bin/lib-path"

CORE="$FLOW_CORE/todo.md"

[ -f "$CORE" ] || exit

DIR="$FLOW_HISTORY/$(flow_history_dir)"
mkdir -p "$DIR"

# ✅ Archive completed items ([v] or [x]) to history
# ✅ 완료된 항목 ([v] 또는 [x])을 history로 이동
grep -E '^\[(v|x)\]' "$CORE" >> "$DIR/todo.md" 2>/dev/null || true

# ✅ Keep only incomplete items, drop empty date headers
# ✅ 미완료 항목만 유지, 빈 날짜 헤더 제거
awk '
BEGIN {
    header=""
    buffer=""
    has_task=0
}

/^[0-9]{4}-[0-9]{2}-[0-9]{2}/ {
    if (has_task) {
        print header
        printf "%s", buffer
    }
    header = $0
    buffer = ""
    has_task = 0
    next
}

/^\[\]/ {
    buffer = buffer $0 "\n"
    has_task = 1
    next
}

END {
    if (has_task) {
        print header
        printf "%s", buffer
    }
}
' "$CORE" > "$CORE.tmp"

mv "$CORE.tmp" "$CORE"

# ✅ Pad to 3 total open tasks
# ✅ 총 3개가 되도록 빈 할 일 추가
remaining=$(grep -c '^\[\]' "$CORE" 2>/dev/null || true)
remaining=${remaining:-0}
new_count=$((3 - remaining))

if [ "$new_count" -gt 0 ]; then
    today="$(flow_today) ($(flow_weekday))"

    if ! grep -q "^$(flow_today)" "$CORE" 2>/dev/null; then
        [ -s "$CORE" ] && echo "" >> "$CORE"
        echo "   $today" >> "$CORE"
    fi

    for _ in $(seq 1 "$new_count"); do
        echo "[] " >> "$CORE"
    done
fi

echo "✅ todo cleaned"
